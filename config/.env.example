# Copy the relevant values into $(herdr plugin config-dir lachieh.cmux-bridge)/.env

# OPTIONAL: only relevant if cmux runs with socketControlMode="password" AND the
# cmux CLI can't auto-read the saved token. With the recommended "automation" mode
# no password exists at all. Leave empty unless doctor tells you otherwise.
CMUX_SOCKET_PASSWORD=

# Click-through bounce target: the cmux workspace hosting the herdr TUI. Explicit
# workspace (uuid or ref) wins; otherwise the bridge finds it by title match.
CMUX_HOST_WORKSPACE=
CMUX_HOST_TITLE=herdr

# Which cmux window to create mirror workspaces in (id | ref | index). If unset,
# cmux uses the caller's window — but the plugin has no window, so set this to a
# real window (see `cmux list-windows`). Leave empty to let cmux decide.
CMUX_WINDOW=

# How to cluster mirror rows in the cmux sidebar:
#   space = one group per herdr space, named after the space (recommended)
#   flat  = one group named CMUX_GROUP for all agents
#   none  = no grouping
GROUP_BY=space
# Group name used only when GROUP_BY=flat.
CMUX_GROUP=herdr agents

# Remove a mirror row when its agent exits/closes (true), or gray it out (false).
REMOVE_ON_EXIT=true

# Keep the last real status pill during a momentary "unknown" instead of flapping to "?".
HOLD_UNKNOWN=true

# Click-through: "focus" = clicking the row runs `herdr agent focus <terminal>`
# (lightweight, recommended). "attach" = the mirror hosts a live attached view.
CLICK_MODE=focus

# Statuses that also raise a cmux notification (comma-separated: idle,working,blocked,done).
NOTIFY_ON=blocked

# How often the optional bridge pane runs a full reconcile (ms).
RECONCILE_INTERVAL_MS=4000

# Show a live "task" line under the agent pill (what the agent is doing right
# now, from `herdr agent explain`). Set for working/blocked, cleared when idle.
TASK_LINE=true
